# ==========================================================================
# .env.example — contrato de variáveis (NUNCA colocar segredos reais aqui)
# Copie para .env.local e preencha. Ver docs/architecture/env-contract.md
# ==========================================================================

# --- App ---
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000

# --- PostgreSQL (db service) ---
POSTGRES_USER=outbound
POSTGRES_PASSWORD=outbound
POSTGRES_DB=outbound
POSTGRES_PORT=5432
# DATABASE_URL é montada a partir das variáveis acima (host=db dentro do compose, localhost fora)
DATABASE_URL=postgresql://outbound:outbound@localhost:5432/outbound?schema=public

# --- Redis (fila + cache) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Brevo (e-mail / outbound) ---
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# --- KIE (gateway multi-modelo de IA) ---
# A KIE embute o modelo no PATH da URL:
#   POST {KIE_BASE_URL}/{KIE_DEFAULT_MODEL}/v1/chat/completions  (formato OpenAI)
# Ex.: https://api.kie.ai/gemini-2.5-flash/v1/chat/completions
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai
KIE_DEFAULT_MODEL=gemini-2.5-flash

# --- Provedores de dados cadastrais (Brasil) ---
CNPJA_API_KEY=
CNPJWS_API_KEY=

# --- Browser research ---
BROWSER_RESEARCH_HEADLESS=true
BROWSER_RESEARCH_TIMEOUT_MS=30000

# --- MinIO (opcional: snapshots, CSVs, anexos) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=outbound-snapshots
